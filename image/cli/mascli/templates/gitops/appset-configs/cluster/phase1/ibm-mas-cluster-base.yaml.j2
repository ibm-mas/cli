merge-key: "{{ ACCOUNT_ID }}/{{ CLUSTER_ID }}"

account:
  id: {{ ACCOUNT_ID }}

region:
  id: {{ REGION_ID }}

cluster:
  id: {{ CLUSTER_ID }}
  url: {{ CLUSTER_URL }}
  nonshared: {{ CLUSTER_NONSHARED }}

sm:
  aws_access_key_id: "<path:{{ SECRETS_PATH }}:{{ SECRET_KEY_AWS_ACCESS_KEY_ID }}>"
  aws_secret_access_key: "<path:{{ SECRETS_PATH }}:{{ SECRET_KEY_AWS_SECRET_ACCESS_KEY }}>"
{% if AVP_TYPE is defined and AVP_TYPE != '' %}
  backend: {{ AVP_TYPE }}
{% endif %}
{% if SECRETS_KEY_SEPARATOR is defined and SECRETS_KEY_SEPARATOR != '' %}
  secret_keys_separator: "{{ SECRETS_KEY_SEPARATOR }}"
{% endif %}

notifications:
  slack_channel_id: {{ SLACK_CHANNEL_ID }}

{% if CUSTOM_LABELS is defined and CUSTOM_LABELS !='' %}
custom_labels:
  {{ CUSTOM_LABELS | indent(2) }}
{% endif %}

{% if DEVOPS_MONGO_URI is defined and DEVOPS_MONGO_URI !='' %}
devops:
  mongo_uri: "<path:{{ SECRETS_PATH }}:{{ SECRET_KEY_DEVOPS_MONGO }}>"
  build_number: {{ DEVOPS_BUILD_NUMBER }}
{% endif %}

{%- if MAS_CLI_IMAGE_REPO is defined and MAS_CLI_IMAGE_REPO != '' %}
cli_image_repo: {{ MAS_CLI_IMAGE_REPO }}
{%- endif %}