      - name: DEVOPS_ENVIRONMENT
        value: $(params.mas_instance_id)
      - name: MAS_INSTANCE_ID
        value: $(params.mas_instance_id)
      - name: FVT_ENVIRONMENT
        value: $(params.mas_instance_id)
      - name: PIPELINE_STORAGE_CLASS
