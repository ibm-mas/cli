module "s3buckets_instance_{{BUCKET_TYPE}}_{{RDS_S3_APP_NAME}}" {
  source = "{{RDS_S3_SOURCE}}"
  depends_on = [module.account_policy_{{BUCKET_TYPE}}_{{RDS_S3_APP_NAME}}]
  tags                    = var.common_tags
  name_prefix             = var.name_prefix
  s3buckets               = local.cluster.instance.rds_s3bucket_{{BUCKET_TYPE}}_{{RDS_S3_APP_NAME}}
  iam_user_arns           = local.iam_user_arns_{{BUCKET_TYPE}}_{{RDS_S3_APP_NAME}}
  bucket_user_name_map    = local.bucket_user_name_map_{{BUCKET_TYPE}}_{{RDS_S3_APP_NAME}}
  iam_users_by_bucket     = local.iam_users_by_bucket_{{BUCKET_TYPE}}_{{RDS_S3_APP_NAME}}
  s3_iam_users_list       = local.s3_iam_users_list_{{BUCKET_TYPE}}_{{RDS_S3_APP_NAME}}
  s3_actions              = local.s3_actions_{{BUCKET_TYPE}}
  s3_encryption           = true
  s3_encryption_algorithm = var.s3_encryption_algorithm
  force_bucket_destroy    = true
  mas_cluster_id          = local.cluster.name
  mas_instance_id         = local.cluster.instance.name
  secret_recovery_days    = 0
  s3_bucket_region        = local.location.region
}