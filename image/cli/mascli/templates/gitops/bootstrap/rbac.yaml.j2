---
apiVersion: v1
kind: ServiceAccount
metadata:
  name: {{ ARGOCLUSTER_NAMESPACE }}-repo-sa
  namespace: {{ ARGOCLUSTER_NAMESPACE }}
---
kind: RoleBinding
apiVersion: rbac.authorization.k8s.io/v1
metadata:
  name: {{ ARGOCLUSTER_NAMESPACE }}
  namespace: {{ ARGOCLUSTER_NAMESPACE }}
subjects:
  - kind: ServiceAccount
    name: {{ ARGOCLUSTER_NAMESPACE }}-repo-sa
    namespace: {{ ARGOCLUSTER_NAMESPACE }}
roleRef:
  apiGroup: rbac.authorization.k8s.io
  kind: ClusterRole
  name: cluster-admin