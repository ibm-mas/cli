---
apiVersion: tekton.dev/v1beta1
kind: Task
metadata:
  name: mas-fvt-start-update
spec:
  params:
    {{ lookup('template', task_src_dir ~ '/common/cli-params.yml.j2') | indent(4) }}

  steps:
    - name: start-update
      script: |
        #!/usr/bin/env bash
        if [[ -n "$DB2_LICENSE" ]]; then
          mas update --catalog $MAS_CATALOG_VERSION_UPDATE $CLI_UPDATE_EXTRA_FLAGS --no-confirm
        else
          echo $DB2_LICENSE | base64 -d >> $(pwd)/db2_license.lic
          mas update --catalog $MAS_CATALOG_VERSION_UPDATE $CLI_UPDATE_EXTRA_FLAGS --db2-license-file $(pwd)/db2_license.lic --no-confirm
        fi
        RESULT=$1
        echo 'MAS LOG'
        echo '--------------------------------------------------------------------------------'
        cat mas.log
        echo '--------------------------------------------------------------------------------'
        exit $RESULT
      timeout: "0"
      image: quay.io/ibmmas/cli:latest
      imagePullPolicy: $(params.image_pull_policy)
      env:
        {{ lookup('template', task_src_dir ~ '/common/cli-env.yml.j2') | indent(8) }}
        - name: MAS_CATALOG_VERSION_UPDATE
          valueFrom:
            secretKeyRef:
              name: mas-fvt-update
              key: MAS_CATALOG_VERSION_UPDATE
              optional: true
        - name: CLI_UPDATE_EXTRA_FLAGS
          valueFrom:
            secretKeyRef:
              name: mas-fvt-update
              key: CLI_UPDATE_EXTRA_FLAGS
              optional: true
        - name: DB2_LICENSE
          valueFrom:
            secretKeyRef:
              name: mas-fvt-update
              key: DB2_LICENSE
              optional: true
