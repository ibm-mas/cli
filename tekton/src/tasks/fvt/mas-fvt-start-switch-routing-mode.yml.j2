---
apiVersion: tekton.dev/v1
kind: Task
metadata:
  name: mas-fvt-start-switch-routing-mode
spec:
  params:
    {{ lookup('template', task_src_dir ~ '/common/cli-params.yml.j2') | indent(4) }}
    - name: mas_instance_id
      type: string
      description: Instance ID
    - name: mas_routing_mode
      type: string
      description: Target routing mode (subdomain or path)

  steps:
    - name: start-switch-routing-mode
      script: |
        #!/usr/bin/env bash
        set -e

        echo "Patching Suite CR to set routingMode to $MAS_ROUTING_MODE"
        oc patch suite $MAS_INSTANCE_ID \
          -n mas-$MAS_INSTANCE_ID-core \
          --type=merge \
          -p "{\"spec\":{\"settings\":{\"routingMode\":\"$MAS_ROUTING_MODE\"}}}"

        echo "Waiting for Suite to reconcile ..."
        RETRIES=0
        MAX_RETRIES=60
        while [[ $RETRIES -lt $MAX_RETRIES ]]; do
          CONDITION=$(oc get suite $MAS_INSTANCE_ID -n mas-$MAS_INSTANCE_ID-core \
            -o jsonpath='{.status.conditions[?(@.type=="Ready")].reason}' 2>/dev/null)
          ROUTING=$(oc get suite $MAS_INSTANCE_ID -n mas-$MAS_INSTANCE_ID-core \
            -o jsonpath='{.spec.settings.routingMode}' 2>/dev/null)
          echo "  Ready reason: $CONDITION  routingMode: $ROUTING"
          if [[ "$CONDITION" == "Ready" && "$ROUTING" == "$MAS_ROUTING_MODE" ]]; then
            echo "Suite is Ready with routingMode=$MAS_ROUTING_MODE"
            exit 0
          fi
          RETRIES=$((RETRIES + 1))
          sleep 60
        done

        echo "Timed out waiting for Suite to become Ready with routingMode=$MAS_ROUTING_MODE"
        exit 1
      timeout: "0"
      image: quay.io/ibmmas/cli:latest
      imagePullPolicy: $(params.image_pull_policy)
      env:
        {{ lookup('template', task_src_dir ~ '/common/cli-env.yml.j2') | indent(8) }}
        - name: MAS_INSTANCE_ID
          value: $(params.mas_instance_id)
        - name: MAS_ROUTING_MODE
          value: $(params.mas_routing_mode)
