---
apiVersion: tekton.dev/v1beta1
kind: Task
metadata:
  name: gitops-db2u-aiservice
spec:
  params:
    - name: cluster_name
      type: string
    - name: account
      type: string
    - name: aiservice_instance_id
      type: string
    - name: git_branch
      type: string
    - name: github_org
      type: string
    - name: github_repo
      type: string
    - name: github_host
      type: string
    - name: secrets_path
      type: string
    - name: avp_aws_secret_region
      type: string
  stepTemplate:
    name: gitops-db2u-aiservice
    env:
      - name: CLUSTER_NAME
        value: $(params.cluster_name)
      - name: ACCOUNT
        value: $(params.account)
      - name: AISERVICE_INSTANCE_ID
        value: $(params.aiservice_instance_id)
      - name: GITHUB_REPO
        value: $(params.github_repo)
      - name: SECRET_PATH
        value: $(params.secrets_path)
      - name: GIT_BRANCH
        value: $(params.git_branch)
      - name: GITHUB_ORG
        value: $(params.github_org)
      - name: GITHUB_HOST
        value: $(params.github_host)
      - name: SM_AWS_REGION
        value: $(params.avp_aws_secret_region)
    envFrom:
      - configMapRef:
          name: environment-properties
          optional: true
      - secretRef:
          name: secure-properties
  steps:
    - args:
      - |-
        set -e
        
        echo "=========================================="
        echo "Generating DB2 Database Configuration for AI Service"
        echo "=========================================="
        
        git config --global user.name "MAS Automation"
        git config --global user.email "you@example.com"
        git config --global user.password $GITHUB_PAT
        
        # Clone the gitops-envs repository
        export GITOPS_WORKING_DIR="/tmp/gitops-db2u-aiservice"
        mkdir -p $GITOPS_WORKING_DIR
        cd $GITOPS_WORKING_DIR
        
        echo "Cloning repository: https://$GITHUB_HOST/$GITHUB_ORG/$GITHUB_REPO"
        git clone https://$GITHUB_PAT@$GITHUB_HOST/$GITHUB_ORG/$GITHUB_REPO -b $GIT_BRANCH
        cd $GITHUB_REPO
        
        # Set up paths
        export GITOPS_CLUSTER_DIR="$GITOPS_WORKING_DIR/$GITHUB_REPO/gitops/$ACCOUNT/$CLUSTER_NAME"
        export CLI_DIR="/mascli"
        export SECRETS_KEY_SEPERATOR="/"
        
        # Export DB2 configuration for AI Service
        export DB2_NAMESPACE="db2u-${AISERVICE_INSTANCE_ID}"
        export DB2_INSTALL_PLAN="Automatic"
        export INSTANCE_ID="$AISERVICE_INSTANCE_ID"
        export CLUSTER_ID="$CLUSTER_NAME"
        export ACCOUNT_ID="$ACCOUNT"
        
        # Set the AWS Secrets Manager keys for DB2
        export SECRET_KEY_DB2_DEFAULT_CHANNEL="${ACCOUNT}/${CLUSTER_NAME}/db2_default_channel#db2_default_channel"
        export SECRET_KEY_IBM_ENTITLEMENT="${ACCOUNT}/${CLUSTER_NAME}/ibm_entitlement#image_pull_secret_b64"
        
        echo "Generating DB2U database configuration file..."
        echo "  Output: ${GITOPS_CLUSTER_DIR}/ibm-db2u-databases.yaml"
        echo "  Template: ${CLI_DIR}/templates/gitops/appset-configs/cluster/instance/ibm-db2u-databases-aiservice.yaml.j2"
        
        # Generate the DB2 database configuration file (separate from operator config)
        jinjanate ${CLI_DIR}/templates/gitops/appset-configs/cluster/instance/ibm-db2u-databases-aiservice.yaml.j2 \
          -o ${GITOPS_CLUSTER_DIR}/ibm-db2u-databases.yaml
        
        echo "DB2U database configuration generated successfully"
        
        # Commit and push changes
        echo "Committing and pushing changes to GitHub..."
        git add ${GITOPS_CLUSTER_DIR}/ibm-db2u-databases.yaml
        git commit -m "Add DB2 database configuration for AI Service instance ${AISERVICE_INSTANCE_ID}" || echo "No changes to commit"
        git push origin $GIT_BRANCH
        
        echo "=========================================="
        echo "DB2 Database Configuration Complete"
        echo "=========================================="
        
        # Cleanup
        cd /
        rm -rf $GITOPS_WORKING_DIR
        
        exit 0
      command:
        - /bin/sh
        - -c
      name: gitops-db2u-aiservice
      imagePullPolicy: IfNotPresent
      image: quay.io/ibmmas/cli:latest
  workspaces:
    - name: configs