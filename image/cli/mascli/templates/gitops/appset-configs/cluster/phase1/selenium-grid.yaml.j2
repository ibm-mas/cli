merge-key: "{{ ACCOUNT_ID }}/{{ CLUSTER_ID }}"

selenium_grid:
  namespace: selenium
  version: 0.36.1
  values:
    hub:
      imageTag: 4.23.0-20240727
      extraEnvironmentVariables:
        - name: SE_SESSION_REQUEST_TIMEOUT
          value: "900"
    chromeNode:
      imageTag: 4.23.0-20240727
      imageName: node-chromium
      extraEnvironmentVariables:
        - name: SE_NODE_SESSION_TIMEOUT
          value: "900"
      resources:
        requests:
          memory: "2Gi"
          cpu: "2"
        limits:
          memory: "4Gi"
          cpu: "2"
    firefoxNode:
      enabled: false
    edgeNode:
      enabled: false
    autoscaling:
      enabled: true
      scalingType: job
      scaledOptions:
        minReplicaCount: 3
        maxReplicaCount: 999
      scaledJobOptions:
        scalingStrategy:
          strategy: default
    ingress:
      hostname: selenium-grid.local
      path: /selenium
