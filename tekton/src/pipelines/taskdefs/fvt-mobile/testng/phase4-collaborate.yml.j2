## Minimum Verification Test for Collaborate
- name: fvt-mob-desktop-collaborate
  taskRef:
    kind: Task
    name: mas-fvt-mobile-testng
  timeout: "0"
  params:
    {{ lookup('template', 'taskdefs/fvt-mobile/common/params-testng.yml.j2') | indent(4) }}
    - name: fvt_mobile_app
      value: Collaborate-Application
    - name: mobile_device_type
      value: chrome
    - name: fvt_test_suite
      value: collaborate-mvt-desktop
  runAfter:
    - fvt-mob-android-mobfound
    - fvt-mob-ios-mobfound
  workspaces:
    - name: configs
      workspace: shared-configs
  when:
    - input: "$(params.fvt_digest_mobile_testng)"
      operator: notin
      values: [""]
    - input: "$(params.mas_app_channel_manage)"
      operator: notin
      values: [""]
    - input: "collaborate"
      operator: in
      values: ["$(tasks.fvt-component.results.component_names[*])"]
    
   
