- name: gencfg-aiservice
  timeout: "0"
  params:
    {{ lookup('template', pipeline_src_dir ~ '/taskdefs/common/cli-params.yml.j2') | indent(4) }}
    - name: devops_suite_name
      value: gencfg-aiservice

    - name: mas_instance_id
      value: $(params.mas_instance_id)
    - name: mas_workspace_id
      value: $(params.mas_workspace_id)
    - name: aiservice_instance_id
      value: $(params.aiservice_instance_id)
    - name: aiservice_channel
      value: $(params.aiservice_channel)
    - name: mas_config_dir
      value: $(params.mas_config_dir)
  taskRef:
    kind: Task
    name: mas-devops-gencfg-aiservice
  workspaces:
    - name: shared-configs
      workspace: shared-configs