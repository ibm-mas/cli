---
apiVersion: tekton.dev/v1beta1
kind: Task
metadata:
  name: gitops-mongo-atlas
spec:
  params:
    - name: cluster_name
      type: string
    - name: account
      type: string
    - name: secrets_path
      type: string
    - name: git_branch
      type: string
    - name: github_org
      type: string
    - name: github_repo
      type: string
    - name: github_host
      type: string
    - name: git_commit_msg
      type: string
    - name: avp_aws_secret_region
      type: string
    - name: atlasURI
      type: string
      default: "https://cloud.mongodb.com/"

    # MongoDB Atlas Resource Configuration
    - name: mongo_action
      type: string
    - name: mongo_major_db_version
      type: string
    - name: mongo_vpc_id
      type: string
    - name: mongo_subnet_ids
      type: string

    # MongoDB Atlas Details
    - name: mongo_project_id
      type: string
    - name: mongo_organization_id
      type: string

    # MongoDB Cluster Configuration
    - name: mongo_instance_size
      type: string
    - name: mongo_node_count
      type: string
      default: "3"
    - name: mongo_shards
      type: string
      default: "1"

    # MongoDB Backup Configuration
    - name: mongo_backup_enabled
      type: string
      default: "true"
    - name: mongo_pit_enabled
      type: string
      default: "true"

    # MongoDB Helm Configuration
    - name: mongo_helm_repo
      type: string
      default: ""
    - name: mongo_namespace
      type: string
      default: "mongodb-atlas-system"

    # Secret Management
    - name: mongo_update_mongo_secret
      type: string
      default: "true"
    - name: mongo_atlasURI
      type: string
      default: "https://cloud.mongodb.com/"
    # MongoDB Auto-Scaling Configuration
    - name: mongo_reset_master_password
      type: string
      default: "false"
    - name: mongo_auto_scaling_enabled
      type: string
      default: "false"
    - name: mongo_compute_enabled
      type: string
      default: "false"
    - name: mongo_scale_down_enabled
      type: string
      default: "false"
    - name: mongo_min_instance_size
      type: string
      default: ""
    - name: mongo_max_instance_size
      type: string
      default: ""
    # MongoDB Cross-Region Backup Configuration
    - name: mongo_cross_region_backup_enabled
      type: string
      default: "false"
    - name: mongo_cross_region_restore_window_days
      type: string
      default: "7"
    - name: mongo_cross_region_backup_regions
      type: string
      default: ""
    - name: mongo_backup_policy_items
      type: string
      default: ""
    - name: mongo_disk_gb_enabled
      type: string
      default: "false"

  stepTemplate:
    name: gitops-mongo-atlas
    env:
      - name: CLUSTER_NAME
        value: $(params.cluster_name)
      - name: ACCOUNT
        value: $(params.account)
      - name: SECRET_PATH
        value: $(params.secrets_path)
      - name: GIT_BRANCH
        value: $(params.git_branch)
      - name: GITHUB_ORG
        value: $(params.github_org)
      - name: GITHUB_HOST
        value: $(params.github_host)
      - name: GITHUB_REPO
        value: $(params.github_repo)
      - name: GIT_COMMIT_MSG
        value: $(params.git_commit_msg)
      - name: SM_AWS_REGION
        value: $(params.avp_aws_secret_region)
      - name: ATLAS_URI
        value: $(params.atlasURI)

      # MongoDB Atlas Resource Configuration
      - name: MONGO_ACTION
        value: $(params.mongo_action)
      - name: MONGO_MAJOR_DB_VERSION
        value: $(params.mongo_major_db_version)
      - name: MONGO_VPC_ID
        value: $(params.mongo_vpc_id)
      - name: MONGO_SUBNET_IDS
        value: $(params.mongo_subnet_ids)

      # MongoDB Atlas Details
      - name: MONGO_PROJECT_ID
        value: $(params.mongo_project_id)
      - name: MONGO_ORGANIZATION_ID
        value: $(params.mongo_organization_id)

      # MongoDB Cluster Configuration
      - name: MONGO_INSTANCE_SIZE
        value: $(params.mongo_instance_size)
      - name: MONGO_NODE_COUNT
        value: $(params.mongo_node_count)
      - name: MONGO_SHARDS
        value: $(params.mongo_shards)

      # MongoDB Backup Configuration
      - name: MONGO_BACKUP_ENABLED
        value: $(params.mongo_backup_enabled)
      - name: MONGO_PIT_ENABLED
        value: $(params.mongo_pit_enabled)

      # MongoDB Helm Configuration
      - name: MONGO_HELM_REPO
        value: $(params.mongo_helm_repo)
      - name: MONGO_NAMESPACE
        value: $(params.mongo_namespace)

      # Secret Management
      # MongoDB Auto-Scaling Configuration
      - name: MONGO_RESET_MASTER_PASSWORD
        value: $(params.mongo_reset_master_password)
      - name: MONGO_AUTO_SCALING_ENABLED
        value: $(params.mongo_auto_scaling_enabled)
      - name: MONGO_COMPUTE_ENABLED
        value: $(params.mongo_compute_enabled)
      - name: MONGO_SCALE_DOWN_ENABLED
        value: $(params.mongo_scale_down_enabled)
      - name: MONGO_MIN_INSTANCE_SIZE
        value: $(params.mongo_min_instance_size)
      - name: MONGO_MAX_INSTANCE_SIZE
        value: $(params.mongo_max_instance_size)
      # MongoDB Cross-Region Backup Configuration
      - name: MONGO_CROSS_REGION_COPY_BACKUP_ENABLED
        value: $(params.mongo_cross_region_backup_enabled)
      - name: MONGO_CROSS_REGION_COPY_BACKUP_RESTORE_WINDOW_DAYS
        value: $(params.mongo_cross_region_restore_window_days)
      - name: MONGO_CROSS_REGION_COPY_BACKUP_REGIONS
        value: $(params.mongo_cross_region_backup_regions)
      - name: MONGO_CROSS_REGION_COPY_BACKUP_POLICY_ITEMS
        value: $(params.mongo_backup_policy_items)
      - name: MONGO_DISK_GB_ENABLED
        value: $(params.mongo_disk_gb_enabled)
      - name: MONGO_UPDATE_MONGO_SECRET
        value: $(params.mongo_update_mongo_secret)
      - name: MONGO_ATLASURI
        value: $(params.mongo_atlasURI)

    envFrom:
      - configMapRef:
          name: environment-properties
          optional: true
      - secretRef:
          name: secure-properties
  steps:
    - args:
      - |-
        git config --global user.name "MAS Automation"
        git config --global user.email "mas_automation@email.com"
        git config --global user.password $GITHUB_PAT

        echo "MongoDB Atlas Configuration"
        echo "Action ......................... ${MONGO_ACTION}"
        echo "Major DB Version ............... ${MONGO_MAJOR_DB_VERSION}"
        echo "VPC ID ......................... ${MONGO_VPC_ID}"
        echo "Subnet IDs ..................... ${MONGO_SUBNET_IDS}"
        echo "Project ID ..................... ${MONGO_PROJECT_ID}"
        echo "Organization ID ................ ${MONGO_ORGANIZATION_ID}"
        echo "Instance Size .................. ${MONGO_INSTANCE_SIZE}"
        echo "Node Count ..................... ${MONGO_NODE_COUNT}"
        echo "Shards ......................... ${MONGO_SHARDS}"

        mkdir -p /tmp/init-mongo-atlas
        mas gitops-mongo-atlas -a $ACCOUNT -c $CLUSTER_NAME \
        --dir /tmp/init-mongo-atlas \
        --github-push \
        --github-host $GITHUB_HOST \
        --github-org  $GITHUB_ORG \
        --github-repo $GITHUB_REPO \
        --git-branch $GIT_BRANCH \
        --secrets-path $SECRET_PATH \
        --atlas-uri $ATLAS_URI \
        --mongo-action $MONGO_ACTION \
        --mongo-major-db-version $MONGO_MAJOR_DB_VERSION \
        --mongo-vpc-id $MONGO_VPC_ID \
        --mongo-subnet-ids $MONGO_SUBNET_IDS \
        --mongo-reset-master-password $MONGO_RESET_MASTER_PASSWORD \
        --mongo-auto-scaling-enabled $MONGO_AUTO_SCALING_ENABLED \
        --mongo-compute-enabled $MONGO_COMPUTE_ENABLED \
        --mongo-scale-down-enabled $MONGO_SCALE_DOWN_ENABLED \
        --mongo-min-instance-size $MONGO_MIN_INSTANCE_SIZE \
        --mongo-max-instance-size $MONGO_MAX_INSTANCE_SIZE \
        --mongo-disk-gb-enabled $MONGO_DISK_GB_ENABLED \
        --mongo-project-id $MONGO_PROJECT_ID \
        --mongo-cross-region-backup-enabled $MONGO_CROSS_REGION_COPY_BACKUP_ENABLED \
        --mongo-cross-region-restore-window-days $MONGO_CROSS_REGION_RESTORE_WINDOW_DAYS \
        --mongo-cross-region-backup-regions $MONGO_CROSS_REGION_BACKUP_REGIONS \
        --mongo-backup-policy-items $MONGO_BACKUP_POLICY_ITEMS \
        --mongo-organization-id $MONGO_ORGANIZATION_ID \
        --mongo-instance-size $MONGO_INSTANCE_SIZE \
        --mongo-node-count $MONGO_NODE_COUNT \
        --mongo-shards $MONGO_SHARDS \
        --mongo-backup-enabled $MONGO_BACKUP_ENABLED \
        --mongo-pit-enabled $MONGO_PIT_ENABLED \
        --mongo-helm-repo $MONGO_HELM_REPO \
        --mongo-namespace $MONGO_NAMESPACE \
        --mongo-atlasURI $MONGO_ATLASURI
        exit $?
      command:
        - /bin/sh
        - -c
      name: gitops-mongo-atlas
      imagePullPolicy: Always
      image: quay.io/ibmmas/cli:latest
  workspaces:
    - name: configs