- name: suite-config-kafka
  timeout: "0"
  params:
    {{ lookup('template', pipeline_src_dir ~ '/taskdefs/common/cli-params.yml.j2') | indent(4) }}
    - name: devops_suite_name
      value: cfg-suite-kafka

    - name: mas_instance_id
      value: $(params.mas_instance_id)
  taskRef:
    kind: Task
    name: mas-devops-suite-config
  # Only load the KafkaCfg if Kafka is required (IoT, Monitor >= 9.2.0, or Civil component enabled)
  when:
    - input: "$(params.kafka_required)"
      operator: in
      values: ["true"]
  workspaces:
    - name: configs
      workspace: shared-configs